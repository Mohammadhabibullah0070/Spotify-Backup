# ─────────────────────────────────────────────────────────────
# Spotify API Configuration
# ─────────────────────────────────────────────────────────────
# 1. Create a Spotify App at https://developer.spotify.com/dashboard
# 2. Copy this file to .env.local
# 3. Fill in your Client ID and Redirect URI below
# 4. NEVER commit .env.local to git
# ─────────────────────────────────────────────────────────────

# Your Spotify App's Client ID
# Found at: https://developer.spotify.com/dashboard → Your App → Settings
VITE_SPOTIFY_CLIENT_ID=your_client_id_here

# Redirect URI — must EXACTLY match your Spotify App settings
# For local development with Vite (npm run dev):
#   http://127.0.0.1:3000/callback
#   OR http://127.0.0.1:5173/callback (depending on Vite port)
#
# For production (deployed):
#   https://your-domain.com/callback
#
# IMPORTANT: Spotify now requires 127.0.0.1 instead of localhost
VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/callback

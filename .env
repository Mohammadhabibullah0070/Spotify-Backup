# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# Found at https://developer.spotify.com/dashboard → Your App → Settings
VITE_SPOTIFY_CLIENT_ID=aa1c0493799b4432b970818c131094b1

# Must EXACTLY match what you added in the Spotify Dashboard
# (including http://, port, and /callback — no trailing slash)
VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/callback
